# IronBoard out-of-band credentials — DO NOT symlink to repo-root .env.local
# Copy to Ironboard/.env.local and set your key here only.
#
# Production platform (:3000) and IronBoard (:8081) may share the same Google
# Cloud project key value, but each runtime loads its own localized file.

GOOGLE_API_KEY=

# Optional — default 8081
# IRONBOARD_PORT=8081

# Optional — default gemini-2.5-flash
# IRONBOARD_GEMINI_MODEL=gemini-2.5-flash

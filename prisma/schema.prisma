datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- AGENT WORKFORCE ENUMS ---
enum RiskTier {
  CRITICAL
  HIGH
  MED
  LOW
}

enum AgentStatus {
  ONLINE
  OFFLINE
  THINKING
  ERROR
}

enum PhysicalUnit {
  KWH
  LITERS
  KILOMETERS
}

// ------------------------------------------------------
// TENANT (Constitutional - Standardized to UUID for RLS)
// ------------------------------------------------------
model Tenant {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String @unique
  industry     String @default("Secure Enclave")
  ale_baseline BigInt @default(0) // ALE math remains BigInt cents

  vendors          Vendor[]
  agent_logs       AgentLog[]
  companies        Company[]
  ironbloomMetrics IronbloomEsgMetric[]

  createdAt DateTime @default(now())

  @@map("tenants")
}

// ------------------------------------------------------
// THE TENANT BOUNDARY (Standardized to BigInt for high-count scale)
// ------------------------------------------------------
model Company {
  id                       BigInt  @id @default(autoincrement())
  name                     String
  sector                   String
  industry_avg_loss_cents  BigInt? // BIGINT Cents
  infrastructure_val_cents BigInt? // BIGINT Cents
  /// Bootstrap / ATTBOT fallback rows — safe to purge without touching prod companies
  isTestRecord             Boolean @default(false) @map("is_test_record")

  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  departments Department[]
  policies    Policy[]
  risks       ActiveRisk[]

  @@index([tenantId])
  @@map("companies")
}

model Department {
  id         BigInt @id @default(autoincrement())
  company_id BigInt
  name       String

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("departments")
}

model Policy {
  id         BigInt @id @default(autoincrement())
  company_id BigInt
  name       String
  status     String
  last_scan  String @default("Today")

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("policies")
}

model ActiveRisk {
  id           BigInt  @id @default(autoincrement())
  company_id   BigInt
  title        String
  status       String
  assigneeId   String? @map("assignee_id")
  score_cents  BigInt // REFACTORED: Unified to BIGINT cents
  source       String
  isSimulation Boolean @default(false) @map("issimulation")

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@map("active_risks")
}

// ------------------------------------------------------
// SUPPLY CHAIN (Standardized to UUID to match Tenant)
// ------------------------------------------------------
model Vendor {
  id       String @id @default(uuid())
  name     String
  riskTier String @default("LOW")
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("vendors")
}

model AgentLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  message   String
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agent_logs")
}

// --- GRC Workflow Enums ---
enum ThreatState {
  PIPELINE // Sitting in SOC/AGENT Stream
  /// Ironlock / Irongate automatic containment (DMZ or malicious verdict)
  QUARANTINED
  ACTIVE // Acknowledged, sitting in Active Threats
  CONFIRMED // Stakeholders emailed, awaiting resolution
  ESCALATED // Irontech Retry-3 exhausted + Phone Home — manual recovery required
  PENDING_REMOTE_INTERVENTION // Manual attempt 4 failed — remote tech dispatch / specialist queue
  RESOLVED // Fix applied, risk mitigated
  DE_ACKNOWLEDGED // Dismissed by operator
}

enum DeAckReason {
  FALSE_POSITIVE
  COMPENSATING_CONTROL
  ACCEPTABLE_RISK
  DUPLICATE
}

/// Irontech (Epic 6): resilient agent operations (Retry-3-then-Escalate).
enum AgentOperationStatus {
  PENDING
  RUNNING
  RETRYING
  CHAOS_INTERRUPTED
  FAILED
  COMPLETED
  ESCALATED
  EXTERNALLY_RESOLVED
}

// --- Core Threat Model ---
model ThreatEvent {
  id                  String @id @default(cuid())
  title               String
  sourceAgent         String // e.g., 'IRONSIGHT', 'COREINTEL'
  score               Int
  targetEntity        String // e.g., 'Healthcare', 'Gridcore Energy'
  financialRisk_cents BigInt @default(0) // Liability in cents (e.g., $4.9M => 490000000)

  // RLS: tenant_isolation_policy depends on this column — do not remove
  tenantCompanyId BigInt?

  // State Machine
  status                   ThreatState  @default(PIPELINE)
  /// Level-3 remote tech dispatch: assigned specialist ref (set on URGENT DISPATCH).
  remoteTechId             String?      @map("remote_tech_id")
  /// GRC: Admin/Owner authorized vendor remote session (column legacy name: remoteAccessAuthorized).
  isRemoteAccessAuthorized Boolean      @default(false) @map("remoteAccessAuthorized")
  ttlSeconds               Int          @default(259200) // 72 hours default
  deAckReason              DeAckReason? // Required if status is DE_ACKNOWLEDGED
  /// Operational owner (execution board / claim); persisted with the threat row
  assigneeId               String?      @map("assignee_id")

  // AI investigation report (CoreIntel agent output)
  aiReport String? @db.Text

  /// Raw Irongate / ingress payload (quarantine details before promotion); optional
  /// Also carries merged JSON: Ironsight `aiTrace`, GRC `grcJustification`, etc. (shallow-merge on write).
  ingestionDetails String? @db.Text

  // Relations
  notes                WorkNote[]
  auditTrail           AuditLog[]
  sustainabilityMetric SustainabilityMetric?
  agentOperations      AgentOperation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantCompanyId])
  @@map("ThreatEvent")
}

/// Agent 11 (Irontech): persisted checkpoint + retry state for orchestration (not Zustand).
model AgentOperation {
  id           String               @id @default(uuid())
  threatId     String
  threat       ThreatEvent          @relation(fields: [threatId], references: [id], onDelete: Cascade)
  agentName    String
  operation    String               @default("STATE_FREEZE")
  status       AgentOperationStatus @default(PENDING)
  payload      Json?
  error        String?
  tenantId     String?              @db.Uuid
  /// Failed-attempt tally for Retry-3; increments on each caught failure.
  attemptCount Int                  @default(0)
  lastError    String?
  snapshot     Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([threatId, agentName])
  @@index([threatId])
  @@index([tenantId])
  @@index([status])
  @@map("AgentOperation")
}

/// Irontech Ironchaos: test harness — injects random failures when active (single global row).
model ChaosConfig {
  id          String   @id @default("global")
  isActive    Boolean  @default(false)
  failureRate Float    @default(0.35)
  updatedAt   DateTime @updatedAt

  @@map("ChaosConfig")
}

/// Singleton app settings (Phone Home target, etc.). Row id is always `global`.
model SystemConfig {
  id              String   @id @default("global")
  /// Irontech escalation / diagnostic delivery (also exposed as admin_alert_email in API).
  adminAlertEmail String?  @map("admin_alert_email")
  updatedAt       DateTime @updatedAt

  @@map("SystemConfig")
}

/// Ironbloom (Epic 5): physical sustainability ledger — kWh, liters, CO2e grams (not USD).
model SustainabilityMetric {
  id                 String      @id @default(uuid())
  threatId           String      @unique
  threat             ThreatEvent @relation(fields: [threatId], references: [id], onDelete: Cascade)
  /// Energy averted by preventing recovery compute (integer kWh).
  kwhAverted         BigInt
  /// Cooling water saved (liters), derived from kWh × factor.
  coolingWaterLiters Float
  /// CO2e reduction in grams (integer).
  carbonOffsetGrams  BigInt
  createdAt          DateTime    @default(now())

  @@map("SustainabilityMetric")
}

// --- Appendable Work Notes ---
model WorkNote {
  id         String @id @default(cuid())
  text       String @db.Text
  operatorId String // The user who wrote the note

  threatId String
  threat   ThreatEvent @relation(fields: [threatId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("WorkNote")
}

// --- Immutable Audit Log ---
model AuditLog {
  id            String  @id @default(cuid())
  action        String // e.g., 'THREAT_ACKNOWLEDGED', 'TTL_CHANGED'
  justification String? @db.Text // Mandatory for De-Ack
  operatorId    String
  isSimulation  Boolean @default(false)

  threatId String?
  threat   ThreatEvent? @relation(fields: [threatId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("AuditLog")
}

/// Immutable workforce audit receipt ledger (19-agent operations + Ironbloom).
model BotAuditLog {
  id                  String              @id @default(cuid())
  tenantId            String              @db.Uuid
  operator            String
  botType             String
  disposition         String
  metadata            Json?
  mitigatedValueCents BigInt? // Native BigInt for rapid risk-baseline calculation
  threatId            String?
  ironbloomMetric     IronbloomEsgMetric?
  createdAt           DateTime            @default(now())

  @@index([tenantId, createdAt])
  @@index([botType])
  @@index([disposition])
  @@index([mitigatedValueCents])
  @@map("BotAuditLog")
}

/// Physical-unit ESG metrics (Ironbloom) with atomic audit linkage.
model IronbloomEsgMetric {
  id               String       @id @default(cuid())
  unit             PhysicalUnit
  quantity         BigInt
  carbonEquivalent BigInt
  metadata         Json?
  auditLogId       String       @unique
  auditLog         BotAuditLog  @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  tenantId         String       @db.Uuid
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([unit])
  @@map("IronbloomEsgMetric")
}

/// LangGraph persistent checkpoint storage (thread-scoped graph memory).
model AgentGraphState {
  id        String   @id @default(cuid())
  threadId  String   @unique // The LangGraph thread identifier
  state     Json // The serialized LangGraph state object
  updatedAt DateTime @updatedAt
  tenantId  String   @db.Uuid // Mandatory RLS isolation

  @@index([tenantId])
  @@map("AgentGraphState")
}

// ------------------------------------------------------
// SOVEREIGN AGENT MODELS
// ------------------------------------------------------

/// Agent 1: Ironcore - Persistence & Self-Healing Registry
model Failed_Jobs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  job_type    String
  payload     Json
  error_state Json
  retry_count Int      @default(0)
  status      String   @default("pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([tenant_id])
  @@index([status])
}

/// Agent 16: Ironscout - Task TTL & Ad-hoc Tracking
model Ironscout_Tasks {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  target_url String
  directive  String
  status     String   @default("active")
  created_at DateTime @default(now())
  expires_at DateTime

  @@index([tenant_id])
  @@index([expires_at])
}

// ------------------------------------------------------
// SYSTEM CONFIG (GRC Template Editor persistence)
// ------------------------------------------------------
model GrcTemplateConfig {
  id                     String   @id // single row keyed by "default"
  generalRfiChecklist    Json // string[]
  vendorTypeRequirements Json // Record<VendorType, string[]>
  updatedAt              DateTime @updatedAt

  @@map("grc_template_config")
}

// ------------------------------------------------------
// IRONWATCH LOG (exists in DB; preserve to avoid db push dropping table)
// ------------------------------------------------------
model IronwatchLog {
  id         String   @id
  event_type String
  actor_id   String
  detail     String
  severity   String   @default("INFO")
  created_at DateTime @default(now())

  @@index([actor_id])
  @@index([created_at])
  @@index([event_type])
  @@map("ironwatch_log")
}

// ------------------------------------------------------
// Irongate quarantine file drop (single-DB; formerly prisma-dmz)
// ------------------------------------------------------
model QuarantineRecord {
  id          String   @id @default(cuid())
  tenantId    String   @db.Uuid
  fileName    String
  fileSize    Int
  storagePath String
  uploadedBy  String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("quarantine_records")
}

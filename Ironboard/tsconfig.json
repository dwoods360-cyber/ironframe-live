{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["../node_modules/@prisma/client"],
      "@prisma/client/*": ["../node_modules/@prisma/client/*"]
    }
  },
  "include": [
    "src/**/*",
    "../lib/ironframeProductKnowledge/**/*",
    "../Ironleads/src/knowledge/**/*",
    "../Ironleads/src/types/**/*",
    "../Ironleads/src/tools/leadGenKnowledgeTools.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/orchestrator.ts",
    "src/state.ts",
    "src/seed.ts",
    "src/agents"
  ]
}

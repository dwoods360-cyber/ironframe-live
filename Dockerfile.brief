# Ultra-lightweight static edge for brief.ironframegrc.com (RSS, brand assets, index/404).
# Build context: repository root.
#   npm run build:rss
#   docker build -f Dockerfile.brief -t ironframe-brief-static .

FROM nginx:alpine

COPY ./public /usr/share/nginx/html
COPY ./docker/brief-static/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]

{
  "version": 0,
  "_comment": "Set PILOT_INVITATION_TOKEN env before running: npm run smoke:pilot-corp:provision prints a fresh token, or export manually.",
  "actions": [
    {
      "name": "pilot_customer",
      "path": "/v1/customers",
      "method": "post",
      "params": {
        "email": "pilot-buyer@ironframe.test",
        "metadata": {
          "tenant_slug": "pilot-corp"
        }
      }
    },
    {
      "name": "pilot_checkout_session",
      "path": "/v1/checkout/sessions",
      "method": "post",
      "params": {
        "mode": "payment",
        "success_url": "https://ironframe.test/success",
        "cancel_url": "https://ironframe.test/cancel",
        "customer": "{pilot_customer:id}",
        "line_items": [
          {
            "price_data": {
              "currency": "usd",
              "unit_amount": 50000,
              "product_data": {
                "name": "Pilot Corp Command Tier"
              }
            },
            "quantity": 1
          }
        ],
        "metadata": {
          "slug": "pilot-corp",
          "companyName": "Pilot Corp",
          "invitationToken": "${.env:PILOT_INVITATION_TOKEN}"
        }
      }
    }
  ],
  "events": [
    {
      "name": "checkout.session.completed",
      "source": "pilot_checkout_session"
    }
  ]
}

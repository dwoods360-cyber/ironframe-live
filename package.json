{
  "name": "ironframe-live",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-dev-port-free.cjs && node -r ./scripts/preload-local-env.cjs node_modules/next/dist/bin/next dev -H 127.0.0.1",
    "dev:clean": "node scripts/ensure-dev-port-free.cjs && node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev",
    "build": "next build",
    "build:rss": "ts-node --project scripts/tsconfig.compile-rss.json scripts/compile-rss.ts",
    "build:newsletters": "npx tsx scripts/compile-newsletters.ts",
    "syndicate:briefings": "npm run build:rss && npm run build:newsletters",
    "sync:brief:gcs:node": "node scripts/sync-brief-gcs.mjs",
    "docker:brief": "npm run build:rss && docker build -f Dockerfile.brief --ignorefile .dockerignore.brief -t ironframe-brief-static .",
    "deploy:brief:gcp": "npm run build:rss && gcloud run deploy governance-frame-brief --source . --dockerfile Dockerfile.brief --ignore-file .dockerignore.brief --project=ironframe-prod --region=us-central1 --allow-unauthenticated",
    "sync:brief:gcs": "npm run build:rss && gcloud storage rsync public gs://brief.ironframegrc.com --recursive --project=ironframe-prod",
    "sync:brief:gcs:verify": "gcloud storage ls --recursive gs://brief.ironframegrc.com/ --project=ironframe-prod",
    "prebuild": "npm run generate:clients && npm run build:rss",
    "start": "next start",
    "lint": "next lint",
    "pretest": "npm run generate:clients",
    "test": "vitest run",
    "test:integration:epic12": "npm run scan:secrets && vitest run tests/unit/signedAttestationGuard.test.ts tests/unit/wormStoragePolicy.test.ts tests/unit/supabaseWormStorage.test.ts tests/unit/threatEventWormGuard.test.ts tests/integration/epic12-shredder-attestation-guard.test.ts",
    "test:integration:epic15": "npm run scan:secrets && vitest run tests/unit/forensicRollback.test.ts tests/unit/epic15DatabaseLock.test.ts tests/unit/triageRouter.test.ts tests/integration/epic15-forensic-rollback.test.ts",
    "scan:secrets": "node scripts/scan-workspace-secrets.mjs",
    "test:integration:epic11": "npm run scan:secrets && vitest run tests/unit/pkiSignatureVerifier.test.ts tests/unit/bankVaultDualGate.test.ts tests/integration/bank-vault-success.test.ts tests/integration/bank-vault-rejection.test.ts tests/integration/pki-verification.test.ts",
    "test:integration:epic13": "npm run scan:secrets && vitest run tests/integration/epic13-telemetry-triage.test.ts tests/integration/cron-auth-gates.test.ts",
    "test:integration:epic14": "vitest run tests/integration/epic14-anonymization-interceptor.test.ts",
    "test:integration:epic16": "vitest run tests/integration/epic16-exports.test.ts",
    "test:integration:epic17": "vitest run tests/integration/epic17-telemetry-stream.test.ts",
    "test:perimeter:briefing": "vitest run tests/unit/briefingInfrastructureLock.test.ts tests/unit/publishBriefingSyndication.test.ts tests/unit/publicBriefingDeclassification.test.ts tests/unit/governanceFrameBriefingScanner.test.ts tests/unit/publishedBriefingFeed.test.ts tests/unit/governanceFrameBriefingLoader.test.ts",
    "test:unit:epic17": "vitest run tests/unit/stateDiffer.test.ts",
    "test:integration:epic10": "npm run scan:secrets && vitest run tests/unit/sovereignOrchestrationBus.test.ts tests/unit/ingestBusBridge.test.ts tests/unit/workforceBusManifest.test.ts",
    "test:integration:sustainability": "npm run scan:secrets && vitest run tests/unit/ironbloomCarbonTelemetry.test.ts tests/unit/ironbloomScoring.test.ts tests/unit/ironbloomRateEngine.test.ts tests/unit/sustainabilityStaleLockdown.test.ts",
    "test:vercel-smoke": "node scripts/staging-smoke-cron.mjs",
    "test:vercel-integration": "node scripts/vercel-integration-suite.mjs --skip-live",
    "test:vercel-integration:live": "node scripts/vercel-integration-suite.mjs",
    "test:vercel-integration:live:epic17": "node scripts/vercel-integration-suite.mjs --include-epic17",
    "test:vercel-integration:cloud:epic17": "node scripts/vercel-integration-suite.mjs --include-epic17 --cloud-only",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:mutants": "stryker run",
    "generate:clients": "npx prisma generate",
    "generate:all": "npx prisma generate && npx tsc --noEmit",
    "check:financial-types": "node scripts/check-no-float-decimal.mjs",
    "install-hooks": "node scripts/install-pre-commit.mjs",
    "cold-store:init": "node scripts/init-ironframe-cold-store.mjs",
    "smoke:worm": "npx tsx scripts/smoke-test-worm.ts",
    "db:seed": "prisma db seed",
    "db:seed:benchmarks": "npx tsx prisma/seedBenchmarks.ts",
    "db:seed:auditor-readiness": "npx tsx scripts/seed-auditor-readiness-telemetry.ts",
    "live-fire:telemetry-ingest": "npx tsx scripts/live-fire-telemetry-ingest.ts",
    "test:epic17-orchestration-shadow-smoke": "node scripts/epic17-orchestration-shadow-smoke.mjs",
    "test:production-compliance-ingest": "node scripts/production-compliance-ingest-probe.mjs",
    "test:production:pki": "node scripts/production-pki-live-probe.mjs",
    "test:production:pki:env": "npx vercel env run -e production -- npx tsx scripts/production-pki-env-probe.ts --vercel-production",
    "provision:production:pki": "node scripts/provision-production-pki.mjs --redeploy",
    "test:e2e:production:pki": "node scripts/run-e2e-production-pki.mjs",
    "db:seed:omni": "npx tsx prisma/stressMarketVolatilitySpike.ts",
    "db:stress:market-spike": "npx tsx prisma/stressMarketVolatilitySpike.ts",
    "db:seed:synthetic": "npx ts-node --project prisma/tsconfig.seed.json prisma/seed-synthetic.ts",
    "dev:stripe:multiplexer": "node scripts/dev/stripe-webhook-multiplexer.mjs",
    "dev:stripe:listen": "stripe listen --forward-to http://127.0.0.1:4242",
    "stripe:provision-catalog": "npx tsx scripts/dev/provision-stripe-catalog.ts",
    "stripe:provision-catalog:production": "npx tsx scripts/ops/provision-stripe-production-catalog.ts",
    "stripe:client-link": "npx tsx scripts/dev/provision-stripe-client-link.ts",
    "smoke:stripe-e2e:provision": "npx tsx scripts/dev/fire-stripe-e2e-provision.ts",
    "smoke:billing:activation": "npx tsx scripts/dev/fire-billing-activation.ts",
    "stripe:activate-tenant": "npx tsx scripts/dev/activate-tenant-billing.ts",
    "smoke:stripe:ironclad": "npx tsx scripts/dev/smoke-stripe-ironclad-local.ts",
    "smoke:stripe:production-ingress": "npx tsx scripts/ops/smoke-stripe-production-ingress.ts",
    "smoke:stripe:production-webhooks": "npx tsx scripts/ops/smoke-stripe-production-webhooks.ts",
    "ops:sync-stripe-production-webhooks": "npx tsx scripts/ops/sync-stripe-production-webhooks.ts",
    "ops:assign-partner-provisioner": "npx tsx scripts/ops/assign-partner-provisioner.ts",
    "ops:assign-global-admin": "npx tsx scripts/ops/assign-global-admin.ts",
    "verify:multiplexer": "npx tsx scripts/dev/verify-multiplexer-integration.ts",
    "synthesize:get-started-audio": "python scripts/synthesize-get-started-audio.py",
    "test:e2e": "playwright test",
    "test:e2e:production:smoke": "node scripts/run-e2e-production-smoke.mjs",
    "ironleads:install": "cd Ironleads && npm install",
    "ironleads:db": "cd Ironleads && npm run db:generate && npm run db:push",
    "ironleads:dev": "cd Ironleads && npm run dev",
    "ironleads:harvest": "cd Ironleads && npm run harvest -- --fixtures-only --skip-ingress",
    "ironboard:install": "cd Ironboard && npm install",
    "ironboard:dev": "cd Ironboard && npm run dev",
    "dev:fleet": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-perimeter-fleet.ps1",
    "salesteam:install": "cd SalesTeam && npm install",
    "salesteam:db": "cd SalesTeam && npm run db:generate && npm run db:push",
    "salesteam:dev": "cd SalesTeam && npm run dev",
    "salesteam:poll": "cd SalesTeam && npm run poll",
    "successteam:install": "cd SuccessTeam && npm install",
    "successteam:db": "cd SuccessTeam && npm run db:generate && npm run db:push",
    "successteam:dev": "cd SuccessTeam && npm run dev",
    "successteam:poll": "cd SuccessTeam && npm run poll",
    "supportteam:install": "cd SupportTeam && npm install",
    "supportteam:db": "cd SupportTeam && npm run db:generate && npm run db:push",
    "supportteam:dev": "cd SupportTeam && npm run dev",
    "supportteam:poll": "cd SupportTeam && npm run poll",
    "fix:supabase-auth-urls": "npx tsx scripts/fix-supabase-auth-urls.ts",
    "test:product-knowledge": "vitest run tests/unit/ironframeProductKnowledge.test.ts tests/unit/productKnowledgeSync.test.ts tests/unit/productKnowledgeOpsCore.test.ts",
    "knowledge:check": "npx tsx scripts/sync-product-knowledge.ts",
    "knowledge:sync": "npx tsx scripts/sync-product-knowledge.ts --apply",
    "knowledge:sync:json": "npx tsx scripts/sync-product-knowledge.ts --apply --json",
    "training:screenshots": "node scripts/capture-training-screenshots.mjs",
    "training:screenshots:live": "node scripts/capture-training-screenshots.mjs --live",
    "crm:pilot-report": "npx tsx scripts/crm-pilot-metrics-report.ts",
    "governance-frame:google-docs": "npx tsx scripts/governance-frame/google-docs/create-research-paper.ts",
    "governance-frame:google-docs:briefs": "npx tsx scripts/governance-frame/google-docs/create-industry-research-briefs.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@google/genai": "^1.52.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.20",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@react-email/components": "^1.0.11",
    "@react-email/render": "^2.0.5",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tremor/react": "^3.18.7",
    "@vercel/speed-insights": "^1.3.1",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.141",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.18.2",
    "googleapis": "^173.0.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "next": "15.1.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-email": "^5.2.10",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.2.1",
    "swr": "^2.4.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.19.33",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "15.1.9",
    "gray-matter": "^4.0.3",
    "jsdom": "^28.1.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^15.1.9"
  }
}

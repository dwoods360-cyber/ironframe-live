datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- AGENT WORKFORCE ENUMS ---
enum RiskTier {
  CRITICAL
  HIGH
  MED
  LOW
}

enum AgentStatus {
  ONLINE
  OFFLINE
  THINKING
  ERROR
}

// ------------------------------------------------------
// TENANT (Constitutional - Standardized to UUID for RLS)
// ------------------------------------------------------
model Tenant {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String @unique
  industry     String @default("Secure Enclave")
  ale_baseline BigInt @default(0) // ALE math remains BigInt cents

  vendors    Vendor[]
  agent_logs AgentLog[]
  companies  Company[]

  createdAt  DateTime   @default(now())

  @@map("tenants")
}

// ------------------------------------------------------
// THE TENANT BOUNDARY (Standardized to BigInt for high-count scale)
// ------------------------------------------------------
model Company {
  id                       BigInt  @id @default(autoincrement())
  name                     String
  sector                   String
  industry_avg_loss_cents  BigInt? // BIGINT Cents
  infrastructure_val_cents BigInt? // BIGINT Cents

  tenantId String  @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  departments Department[]
  policies    Policy[]
  risks       ActiveRisk[]

  @@index([tenantId])
  @@map("companies")
}

model Department {
  id         BigInt @id @default(autoincrement())
  company_id BigInt
  name       String

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("departments")
}

model Policy {
  id         BigInt @id @default(autoincrement())
  company_id BigInt
  name       String
  status     String
  last_scan  String @default("Today")

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("policies")
}

model ActiveRisk {
  id             BigInt   @id @default(autoincrement())
  company_id     BigInt
  title          String
  status         String
  score_cents    BigInt   // REFACTORED: Unified to BIGINT cents
  source         String
  isSimulation   Boolean  @default(false) @map("issimulation")

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@map("active_risks")
}

// ------------------------------------------------------
// SUPPLY CHAIN (Standardized to UUID to match Tenant)
// ------------------------------------------------------
model Vendor {
  id       String @id @default(uuid())
  name     String
  riskTier String @default("LOW")
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("vendors")
}

model AgentLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  message   String
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agent_logs")
}

// --- GRC Workflow Enums ---
enum ThreatState {
  PIPELINE // Sitting in SOC/AGENT Stream
  ACTIVE // Acknowledged, sitting in Active Threats
  CONFIRMED // Stakeholders emailed, awaiting resolution
  RESOLVED // Fix applied, risk mitigated
  DE_ACKNOWLEDGED // Dismissed by operator
}

enum DeAckReason {
  FALSE_POSITIVE
  COMPENSATING_CONTROL
  ACCEPTABLE_RISK
  DUPLICATE
}

// --- Core Threat Model ---
model ThreatEvent {
  id             String @id @default(cuid())
  title          String
  sourceAgent    String // e.g., 'IRONSIGHT', 'COREINTEL'
  score          Int
  targetEntity   String // e.g., 'Healthcare', 'Gridcore Energy'
  financialRisk_cents BigInt @default(0) // Liability in cents (e.g., $4.9M => 490000000)

  // RLS: tenant_isolation_policy depends on this column — do not remove
  tenantCompanyId BigInt?

  // State Machine
  status      ThreatState  @default(PIPELINE)
  ttlSeconds  Int          @default(259200) // 72 hours default
  deAckReason DeAckReason? // Required if status is DE_ACKNOWLEDGED

  // AI investigation report (CoreIntel agent output)
  aiReport String? @db.Text

  // Relations
  notes      WorkNote[]
  auditTrail AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantCompanyId])
}

// --- Appendable Work Notes ---
model WorkNote {
  id         String @id @default(cuid())
  text       String @db.Text
  operatorId String // The user who wrote the note

  threatId String
  threat   ThreatEvent @relation(fields: [threatId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// --- Immutable Audit Log ---
model AuditLog {
  id            String   @id @default(cuid())
  action        String   // e.g., 'THREAT_ACKNOWLEDGED', 'TTL_CHANGED'
  justification String?  @db.Text // Mandatory for De-Ack
  operatorId    String
  isSimulation  Boolean  @default(false)

  threatId String?
  threat   ThreatEvent? @relation(fields: [threatId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ------------------------------------------------------
// SOVEREIGN AGENT MODELS
// ------------------------------------------------------

/// Agent 1: Ironcore - Persistence & Self-Healing Registry
model Failed_Jobs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  job_type    String
  payload     Json
  error_state Json
  retry_count Int      @default(0)
  status      String   @default("pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([tenant_id])
  @@index([status])
}

/// Agent 16: Ironscout - Task TTL & Ad-hoc Tracking
model Ironscout_Tasks {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  target_url String
  directive  String
  status     String   @default("active")
  created_at DateTime @default(now())
  expires_at DateTime

  @@index([tenant_id])
  @@index([expires_at])
}

// ------------------------------------------------------
// SYSTEM CONFIG (GRC Template Editor persistence)
// ------------------------------------------------------
model GrcTemplateConfig {
  id                     String   @id // single row keyed by "default"
  generalRfiChecklist     Json     // string[]
  vendorTypeRequirements Json     // Record<VendorType, string[]>
  updatedAt              DateTime @updatedAt
  @@map("grc_template_config")
}

// ------------------------------------------------------
// IRONWATCH LOG (exists in DB; preserve to avoid db push dropping table)
// ------------------------------------------------------
model IronwatchLog {
  id         String   @id
  event_type String
  actor_id   String
  detail     String
  severity   String   @default("INFO")
  created_at DateTime @default(now())

  @@index([actor_id])
  @@index([created_at])
  @@index([event_type])
  @@map("ironwatch_log")
}

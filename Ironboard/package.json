{
  "name": "ironboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "predev": "npm run stop",
    "dev": "node --import tsx src/index.ts",
    "dev:safe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-board.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-board.ps1"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@prisma/client": "^6.19.2",
    "express": "^5.2.1",
    "react": "^19.0.0",
    "resend": "^4.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

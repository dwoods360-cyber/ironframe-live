generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                         String
  slug                         String                      @unique
  industry                     String?
  shareAnonymizedBenchmarks    Boolean                     @default(false)
  ale_baseline                 BigInt                      @default(0)
  createdAt                    DateTime                    @default(now())
  /// Ironlock: hard-banned adversary correlated to this tenant — drives Audit Intelligence siege UX.
  isUnderTargetedSiege         Boolean                     @default(false) @map("is_under_targeted_siege")
  /// Successful constitutional chaos drill — lifts quarantine maturity penalty until next adversarial activity.
  lastChaosForensicHardeningAt DateTime?                   @map("last_chaos_forensic_hardening_at")
  riskEvents                   RiskEvent[]
  agentComputeLogs             AgentComputeLog[]
  agent_logs                   AgentLog[]
  audit_exports                audit_exports[]
  companies                    Company[]
  compliance_snapshots         compliance_snapshots[]
  forensicSealLedgers          ForensicSealLedger[]
  governance_policy_history    governance_policy_history[]
  governance_settings          governance_settings?
  riskRegistry                 RiskRegistry[]
  vendors                      Vendor[]
  gridcoreCarbonCoefficients   GridcoreCarbonCoefficient[]
  carbonPulseSamples           CarbonPulseSample[]
  dirtyGridAlerts              DirtyGridAlert[]
  ironlockCarbonThrottles      IronlockCarbonThrottle[]
  utilityRateCaches            IronbloomUtilityRateCache[]
  rateDriftAlerts              IronbloomRateDriftAlert[]
  ironbloomSyncMeta            IronbloomTenantSyncMeta?

  @@map("tenants")
}

/// Agentic compute telemetry — HASH-partitioned by `tenant_id` for billing and audit (Postgres 18).
model AgentComputeLog {
  tenantId      String   @map("tenant_id") @db.Uuid
  id            String   @default(cuid())
  agentId       String   @map("agent_id")
  durationMs    Int      @map("duration_ms")
  tokensIn      Int      @default(0) @map("tokens_in")
  tokensOut     Int      @default(0) @map("tokens_out")
  operationType String   @map("operation_type")
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("agent_compute_log")
}

/// Weekly anonymized industry mean ALE (cents) for Ironethic benchmark trend charts.
model MarketBenchmarkSnapshot {
  id              String   @id @default(cuid())
  industry        String
  averageAleCents BigInt   @map("average_ale_cents")
  timestamp       DateTime @default(now())

  @@index([industry, timestamp])
  @@map("market_benchmark_snapshots")
}

model Company {
  id                       BigInt       @id @default(autoincrement())
  name                     String
  sector                   String
  industry_avg_loss_cents  BigInt?
  infrastructure_val_cents BigInt?
  /// Bootstrap / ATTBOT fallback rows — safe to purge without touching prod companies
  isTestRecord             Boolean      @default(false) @map("is_test_record")
  tenantId                 String       @db.Uuid
  risks                    ActiveRisk[]
  tenant                   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments              Department[]
  policies                 Policy[]

  @@index([tenantId])
  @@map("companies")
}

model Department {
  id         BigInt  @id @default(autoincrement())
  company_id BigInt
  name       String
  company    Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("departments")
}

model Policy {
  id         BigInt  @id @default(autoincrement())
  company_id BigInt
  name       String
  status     String
  last_scan  String  @default("Today")
  company    Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("policies")
}

model ActiveRisk {
  id           BigInt  @id @default(autoincrement())
  company_id   BigInt
  title        String
  status       String
  assigneeId   String? @map("assignee_id")
  score_cents  BigInt
  source       String
  isSimulation Boolean @default(false) @map("issimulation")
  company      Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@map("active_risks")
}

model Vendor {
  id       String @id @default(uuid())
  name     String
  riskTier String @default("LOW")
  tenantId String @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("vendors")
}

model AgentLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  message   String
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agent_logs")
}

model ThreatEvent {
  id                       String                @id @default(cuid())
  title                    String
  sourceAgent              String
  score                    Int
  targetEntity             String
  financialRisk_cents      BigInt                @default(0)
  tenantCompanyId          BigInt?
  status                   ThreatState           @default(IDENTIFIED)
  /// Level-3 remote tech dispatch: assigned specialist ref (set on URGENT DISPATCH).
  remoteTechId             String?               @map("remote_tech_id")
  /// GRC: Admin/Owner authorized vendor remote session (column legacy name: remoteAccessAuthorized).
  isRemoteAccessAuthorized Boolean               @default(false) @map("remoteAccessAuthorized")
  ttlSeconds               Int                   @default(259200)
  deAckReason              DeAckReason?
  /// Operational owner (execution board / claim); persisted with the threat row
  assigneeId               String?               @map("assignee_id")
  aiReport                 String?
  /// Raw Irongate / ingress payload (quarantine details before promotion); optional
  /// Also carries merged JSON: Ironsight `aiTrace`, GRC `grcJustification`, etc. (shallow-merge on write).
  ingestionDetails         String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  /// GRC disposition label (e.g. CLEARANCE_PASSED, CLEARANCE_FALSE_POSITIVE); optional until triaged.
  dispositionStatus        String?               @map("disposition_status")
  /// GRC disposition: operator marked the finding as a false positive (twin shadow row: `RiskEvent` / table `SimThreatEvent`).
  isFalsePositive          Boolean               @default(false) @map("is_false_positive")
  /// SHA-256 hex of canonical digital receipt JSON at last disposition commit (golden-source anchor).
  receiptHash              String?               @map("receipt_hash")
  ingestion_fingerprint    String?               @unique
  resolutionApprovalId     String?               @map("resolution_approval_id")
  /// Financial + sustainability ALE rollup (native cents; replaces JSON metadata proxies).
  mitigatedValueCents      BigInt?               @map("mitigated_value_cents")
  agentOperations          AgentOperation[]
  auditTrail               AuditLog[]
  sustainabilityMetric     SustainabilityMetric?
  assignments              ThreatAssignment[]
  resolutionApproval       ThreatApproval?       @relation("ThreatResolutionApproval", fields: [resolutionApprovalId], references: [id])
  notes                    WorkNote[]
  agentReasonings          AgentReasoning[]
  approvals                ThreatApproval[]

  @@index([tenantCompanyId])
  @@index([resolutionApprovalId])
  @@map("ThreatEvent")
}

/// Agent-orchestration reasoning (append-only / read-only in product UI). One row per agent per threat.
model AgentReasoning {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now()) @map("created_at")
  agentId   String      @map("agent_id")
  threatId  String      @map("threat_id")
  reasoning String
  metadata  Json        @default("{}")
  threat    ThreatEvent @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@unique([agentId, threatId])
  @@index([threatId])
  @@map("agent_reasoning")
}

/// Shadow / simulation plane risk ledger (`ironframe-simulation-mode=1`): mirrors `ThreatEvent` scalars (Epic 11 — framework-mapped control exposure).
/// HASH-partitioned by `tenant_id` (Postgres declarative); composite PK prevents cross-tenant row identity collisions at the storage layer.
model RiskEvent {
  id                         String               @default(cuid())
  title                      String
  sourceAgent                String
  source                     SimThreatSource      @default(SYSTEM)
  score                      Int
  targetEntity               String
  financialRisk_cents        BigInt               @default(0)
  /// Immutable base impact (cents) — DB-level law: governed_impact = (base_impact_cents * governance_impact_multiplier) / 100.
  /// Example: 1.6× governance uses multiplier 160 → same integer cents as (base_impact_cents * 160) / 100.
  baseImpactCents            BigInt               @default(0) @map("base_impact_cents")
  /// Integer multiplier in basis points (100 = 1.00×, 160 = 1.60×). All monetary fields BigInt.
  governanceImpactMultiplier BigInt               @default(100) @map("governance_impact_multiplier")
  /// SHA-256 (hex) CISO/PO attestation + ingestion anchor (see `lib/crypto` canonical binding).
  governanceHash             String?              @map("governance_hash")
  tenantCompanyId            BigInt?
  /// Denormalized from `companies.tenantId` — HASH partition key (NOT NULL for partitioned rows).
  tenantId                   String               @map("tenant_id") @db.Uuid
  status                     ThreatState          @default(IDENTIFIED)
  /// Epic 11: primary compliance framework for this risk event (HUD prioritizes drift vs. control mapping).
  complianceFramework        ComplianceFramework  @default(SOC2)
  /// Mapped control identifiers (e.g. SOC2 CC6.1, ISO A.8.2, NIST PR.AC-3).
  mappedControls             String[]             @default([])
  remoteTechId               String?              @map("remote_tech_id")
  isRemoteAccessAuthorized   Boolean              @default(false) @map("remoteAccessAuthorized")
  ttlSeconds                 Int                  @default(259200)
  monitoringExpiry           DateTime?
  deAckReason                DeAckReason?
  assigneeId                 String?              @map("assignee_id")
  aiReport                   String?
  /// Shadow-plane metadata as JSONB (Prisma `Json`) — use `mergeIngestionDetailsPatchJson` on writes.
  ingestionDetails           Json?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  dispositionStatus          String?              @map("disposition_status")
  isFalsePositive            Boolean              @default(false) @map("is_false_positive")
  receiptHash                String?              @map("receipt_hash")
  assignment_history         Json?
  category                   String?
  impact_radius              Float?
  priority_score             Int                  @default(0)
  remediation_status         String               @default("PENDING")
  severity                   String               @default("LOW")
  /// Predictive exposure map from Ironlogic: `{ assetName: heatValue }` (resilience audit positioning).
  predictedAssets            Json?
  /// Resilience audit / drill progression multiplier used in predictive overlay scoring.
  threatVelocity             Float                @default(1.0)
  ingestion_fingerprint      String?
  /// GRC post-mortem PDF path (local `uploads/...` or `supabase://bucket/...`) after expert Gate 7 resolve.
  postMortemReportPath       String?              @map("post_mortem_report_path")
  /// GRC Gold — Product Owner digital signature + verification metadata (JSONB).
  forensicSeal               Json?                @map("forensic_seal")
  /// Postgres GENERATED ALWAYS STORED BIGINT — expression lives in migrations / DB.
  governedImpact             BigInt               @default(dbgenerated("((base_impact_cents * governance_impact_multiplier) / 100)")) @map("governed_impact")
  /// Sustainability / combined mitigated ALE cents (BigInt; migrated from JSON audit metadata).
  mitigatedValueCents        BigInt?              @map("mitigated_value_cents")
  AuditLog                   AuditLog[]
  reasoningLogs              ReasoningLog[]
  tenant                     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidenceChapter            EvidenceChapter?
  forensicSealLedgerRows     ForensicSealLedger[]

  @@id([tenantId, id])
  @@unique([tenantId, ingestion_fingerprint])
  @@index([tenantCompanyId])
  @@index([tenantId])
  @@index([complianceFramework])
  @@map("SimThreatEvent")
}

/// HASH-partitioned forensic seal snapshots (`forensic_seal_ledger`); complements JSONB `forensic_seal` on RiskEvent.
model ForensicSealLedger {
  tenantId       String    @map("tenant_id") @db.Uuid
  id             String
  riskEventId    String    @map("risk_event_id")
  governanceHash String?   @map("governance_hash")
  sealJson       Json      @map("seal_json")
  createdAt      DateTime  @default(now()) @map("created_at")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  riskEvent      RiskEvent @relation(fields: [tenantId, riskEventId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, id])
  @@index([riskEventId])
  @@map("forensic_seal_ledger")
}

/// Evidence vault chapter metadata — export control & clearance (shadow-plane RiskEvent attachment).
model EvidenceChapter {
  id                 String    @id @default(cuid())
  riskEventTenantId  String    @map("risk_event_tenant_id") @db.Uuid
  riskEventId        String    @map("risk_event_id")
  isExportControlled Boolean   @default(false) @map("is_export_controlled")
  requiredClearance  String    @default("PUBLIC") @map("required_clearance")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  riskEvent          RiskEvent @relation(fields: [riskEventTenantId, riskEventId], references: [tenantId, id], onDelete: Cascade)

  @@unique([riskEventTenantId, riskEventId])
  @@map("evidence_chapters")
}

/// Simulated PERSEC / personnel clearance elevation (Defense & Aerospace restricted chapters).
model ClearanceRequest {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Supabase `auth.users` id (or `shadow-operator` when unauthenticated in simulation).
  userId          String   @map("user_id")
  riskEventId     String?  @map("risk_event_id")
  targetClearance String   @map("target_clearance")
  status          String   @default("PENDING")
  justification   String
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId, status])
  @@index([riskEventId])
  @@map("clearance_requests")
}

/// Non-repudiable certificate of destruction (NIST 800-88 digital shred) — Ironwatch-attested.
model AuditReceipt {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id") @db.Uuid
  riskEventId       String   @map("risk_event_id")
  receiptNumber     String   @unique @map("receipt_number")
  narrative         String
  receiptHashSha256 String   @map("receipt_hash_sha256")
  titleSnapshot     String   @map("title_snapshot")
  sectorSnapshot    String?  @map("sector_snapshot")
  aleImpactCents    String   @map("ale_impact_cents")
  shreddedByUserId  String   @map("shredded_by_user_id")
  shreddedAt        DateTime @default(now()) @map("shredded_at")

  @@unique([tenantId, riskEventId])
  @@index([tenantId, shreddedAt])
  @@map("audit_receipts")
}

/// Agentic brain — self-correction ledger (shadow `RiskEvent` plane). Confidence + escalation math are audit-facing.
model ReasoningLog {
  id              String     @id @default(cuid())
  /// Filled by `lib/prisma` query extension from `threatId` + `SimThreatEvent.tenant_id` before INSERT.
  threatTenantId  String?    @map("threat_tenant_id") @db.Uuid
  threatId        String
  agentName       String
  /// Optional asset focus label (e.g. "Primary_DB", "Auth_Gateway", "S3_Bucket_01").
  targetAsset     String?
  /// The math (e.g. V*P + B)
  escalationLogic String?
  /// Step-by-step strategy
  plan            Json
  reasoning       String
  /// 0.0–1.0 (audit band)
  confidence      Float
  isCorrection    Boolean    @default(false)
  /// AUTONOMOUS or HYBRID
  operationalMode String     @default("AUTONOMOUS")
  createdAt       DateTime   @default(now())
  threat          RiskEvent? @relation(fields: [threatTenantId, threatId], references: [tenantId, id], onDelete: Cascade)

  @@index([threatTenantId, threatId])
  @@index([agentName])
  @@index([targetAsset])
}

/// Agent 17 — durable outbox for scheduled Sentinel sweeps (`pg_cron` inserts PENDING rows; HTTP/worker drains).
model SentinelAutomationOutbox {
  id          String    @id @default(uuid()) @db.Uuid
  jobKind     String    @default("AGENT17_SENTINEL_SWEEP") @map("job_kind")
  tenantScope String?   @map("tenant_scope") @db.Uuid
  status      String    @default("PENDING")
  runAfter    DateTime  @default(now()) @map("run_after")
  createdAt   DateTime  @default(now()) @map("created_at")
  payload     Json?
  claimedAt   DateTime? @map("claimed_at")
  completedAt DateTime? @map("completed_at")
  lastError   String?   @map("last_error")

  @@map("sentinel_automation_outbox")
}

/// Shadow-plane only: structural self-test & deficiency trail (never ThreatEvent / production ledger).
model SimulationDiagnosticLog {
  id          String    @id @default(cuid())
  tenantUuid  String    @db.Uuid
  simThreatId String?
  action      String
  payload     Json
  operatorId  String
  createdAt   DateTime  @default(now())
  /// Set when a deficiency report row is cleared (GRC 4.9 TTR); null while unresolved.
  resolvedAt  DateTime?

  @@index([tenantUuid, createdAt])
  @@index([simThreatId])
  @@map("SimulationDiagnosticLog")
}

/// Global Integrity / Control Room simulation flags (single row `id = "global"`). Secure-by-default: no automated stakeholder posts until explicitly enabled.
model SimulationConfig {
  id                                   String             @id
  automatedUpdatesEnabled              Boolean            @default(false) @map("automated_updates_enabled")
  /// Executive board report: minimum operational readiness score before UI enters BREACHED state.
  targetReadinessScore                 Int                @default(90) @map("target_readiness_score")
  /// Compliance badge latch: set true once 7-day resilience criteria is satisfied.
  isCertified                          Boolean            @default(false) @map("is_certified")
  /// UTC instant certification was awarded.
  certifiedAt                          DateTime?          @map("certified_at")
  /// Lifecycle state for 30-day certificate validity.
  certificateStatus                    CertificateStatus  @default(IN_PROGRESS) @map("certificate_status")
  /// UTC instant for certificate issuance; validity window is 30 days.
  certificateIssuedAt                  DateTime?          @map("certificate_issued_at")
  /// Lowest operational readiness score observed (0–100); updated when a new minimum is recorded.
  historicalLowestScore                Int                @default(100) @map("historical_lowest_score")
  /// UTC instant when `historicalLowestScore` was last set (baseline seed or new low).
  historicalLowestRecordedAt           DateTime?          @map("historical_lowest_recorded_at")
  /// Consecutive daily snapshots meeting resilience threshold (score >= 95).
  currentStreak                        Int                @default(0) @map("current_streak")
  /// Best streak on record (all-time high resilience run).
  longestStreak                        Int                @default(0) @map("longest_streak")
  /// Most recent primary reason for streak reset (post-mortem classifier).
  lastResetReason                      StreakResetReason? @map("last_reset_reason")
  /// Start of active 2-hour streak protection grace window (50+ day streak only).
  graceWindowStartedAt                 DateTime?          @map("grace_window_started_at")
  /// End of active 2-hour streak protection grace window.
  graceWindowExpiresAt                 DateTime?          @map("grace_window_expires_at")
  /// Count of recovered grace windows where readiness was restored before expiry.
  successfulGraceRecoveries            Int                @default(0) @map("successful_grace_recoveries")
  /// Legacy badge for operators with 5+ successful grace recoveries.
  isEliteOperator                      Boolean            @default(false) @map("is_elite_operator")
  /// Analyst maturation: threat-library deep dives completed in Strategic Intel.
  completedDeepDives                   String[]           @default([]) @map("completed_deep_dives")
  /// UTC instant when the latest Strategic Intel drill was launched.
  lastSimulationStartedAt              DateTime?          @map("last_simulation_started_at")
  /// Per-tenant ISO timestamps: `{ "<tenantUuid>": "<expiresAtIso>" }` — set after Master Purge to silence auto-inject.
  simulationStandDownExpiresAtByTenant Json?              @map("simulation_stand_down_expires_at_by_tenant")
  /// Active Risks panic: freezes gate progression and forces passive observation across the workforce roster.
  workforcePanicPassiveMonitor         Boolean            @default(false) @map("workforce_panic_passive_monitor")
  workforcePanicEngagedAt              DateTime?          @map("workforce_panic_engaged_at")
  workforcePanicAuthorityLabel         String?            @map("workforce_panic_authority_label") @db.VarChar(128)
  updatedAt                            DateTime           @updatedAt @map("updated_at")

  @@map("simulation_config")
}

/// Board Report: one UTC calendar row per day — readiness score + aggregate synthetic loss snapshot.
model DailySnapshot {
  id               String    @id @default(cuid())
  date             DateTime  @unique @db.Date
  score            Int
  totalLossCents   BigInt    @default(0) @map("total_loss_cents")
  premiumCents     BigInt    @default(0) @map("premium_cents")
  executiveSummary String?   @map("executive_summary")
  isApproved       Boolean   @default(false) @map("is_approved")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("daily_snapshots")
}

/// Historical post-mortem ledger for resilience streak resets.
model StreakFailureLog {
  id                      String            @id @default(cuid())
  reason                  StreakResetReason
  resetAt                 DateTime          @default(now()) @map("reset_at")
  lostStreakDays          Int               @map("lost_streak_days")
  isExcludedFromAnalytics Boolean           @default(false) @map("is_excluded_from_analytics")
  exclusionReason         String?           @map("exclusion_reason") @db.VarChar(256)

  @@index([reason, resetAt])
  @@map("streak_failure_logs")
}

model NotificationEndpoint {
  id              String                  @id @default(cuid())
  name            String
  urlEncrypted    String                  @map("url_encrypted")
  channelType     NotificationChannelType @map("channel_type")
  isEnabled       Boolean                 @default(true) @map("is_enabled")
  /// Last connectivity test (does not change `isEnabled` on failure).
  lastProbeAt     DateTime?               @map("last_probe_at")
  lastProbeOk     Boolean?                @map("last_probe_ok")
  lastProbeDetail String?                 @map("last_probe_detail") @db.VarChar(512)
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  @@index([isEnabled])
  @@map("notification_endpoints")
}

/// Community-safe anonymized lessons repository (export-ready tactical intelligence only).
model CommunityInsights {
  id                      String   @id @default(cuid())
  sourceThreatId          String   @map("source_threat_id")
  anonymizedSummary       Json     @map("anonymized_summary")
  predictiveAccuracyScore Float?   @map("predictive_accuracy_score")
  mitigationStrategy      String?  @map("mitigation_strategy")
  exportHash              String   @map("export_hash")
  createdAt               DateTime @default(now()) @map("created_at")

  @@index([sourceThreatId, createdAt])
  @@map("community_insights")
}

/// Shared community intelligence repository used for weighted predictive overlays.
model CommunityIntelligence {
  id               String   @id @default(cuid())
  patternData      Json     @map("pattern_data")
  credibilityScore Float    @default(1.0) @map("credibility_score")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([active, createdAt])
  @@map("community_intelligence")
}

/// Shadow directory for simulator-only targets (never maps to real authentication users / production directory).
model SyntheticEmployee {
  id                 String                  @id @default(uuid())
  name               String
  /// Simulator inbox only (e.g. target-01@ironframe.local) — not routable production mail.
  email              String                  @unique
  role               String
  /// Effective clearance tier 1–5 for simulation scoping (InfilBot / PhishBot selection).
  clearanceLevel     Int
  vulnerabilityScore Float
  /// Access / blast-radius economics in USD **cents** (e.g. 50_000_000 = $500,000.00).
  monetaryValue      BigInt                  @default(0)
  /// Last time this persona was selected for a simulated attack (null = never).
  lastAttackedAt     DateTime?
  /// Cumulative simulated financial loss in USD cents.
  totalLossIncurred  BigInt                  @default(0)
  /// Level-5 VIP: blue-team hardening spend halves effective PhishBot vulnerability on hook rolls.
  isHardened         Boolean                 @default(false) @map("is_hardened")
  /// Active shadow-plane compromise state for per-target restore controls.
  isBreached         Boolean                 @default(false) @map("is_breached")
  /// Runtime protection state shown in Shadow Plane registry.
  status             SyntheticEmployeeStatus @default(PROTECTED)
  createdAt          DateTime                @default(now())

  @@index([vulnerabilityScore])
  @@map("SyntheticEmployee")
}

/// GRC execution-board assignments (tenant-scoped). Purge before `ThreatEvent` to avoid P2003.
model ThreatAssignment {
  id       String      @id @default(cuid())
  threatId String
  tenantId String      @db.Uuid
  threat   ThreatEvent @relation(fields: [threatId], references: [id])

  @@index([threatId])
  @@index([tenantId])
  @@map("ThreatAssignment")
}

/// Agent 04 (Irontech): persisted checkpoint + retry state for orchestration (not Zustand).
model AgentOperation {
  id           String               @id @default(uuid())
  threatId     String
  agentName    String
  status       AgentOperationStatus @default(PENDING)
  /// Failed-attempt tally for Retry-3; increments on each caught failure.
  attemptCount Int                  @default(0)
  lastError    String?
  snapshot     Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  threat       ThreatEvent          @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@unique([threatId, agentName])
  @@index([threatId])
  @@index([status])
  @@map("AgentOperation")
}


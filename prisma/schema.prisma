  sentAt          DateTime @map("sent_at")
  previousRateUsd Float    @map("previous_rate_usd")
  newRateUsd      Float    @map("new_rate_usd")
  driftRatio      Float    @map("drift_ratio")
  unitType        String   @map("unit_type")
  pulseMessage    String   @map("pulse_message")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, id])
  @@map("ironbloom_rate_drift_alerts")
}

model IronbloomTenantSyncMeta {
  tenantId                 String    @id @map("tenant_id") @db.Uuid
  lastSynchronizedAt       DateTime? @map("last_synchronized_at")
  lastGlobalPollAt         DateTime? @map("last_global_poll_at")
  lastDirtyAlertAtByTenant DateTime? @map("last_dirty_alert_at")
  tenant                   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ironbloom_tenant_sync_metas")
}

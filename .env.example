# ==============================================================================
# IRONFRAME SYSTEM ARCHITECTURE — ENVIRONMENT BLUEPRINT (.env.example)
# ==============================================================================
# Copy to `.env.local` (or `.env` for local-only use). Never commit real secrets.
# Prisma CLI loads `.env` then `.env.local` (override) via `prisma.config.ts`.

# --- Core database (Prisma; see prisma/schema.prisma) ---
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ironframe_dev?schema=public
# DIRECT_URL=postgresql://postgres:password@localhost:5432/ironframe_dev?schema=public

# --- Multi-agent ingest & telemetry routing ---
# Path A (Sovereign bus override) = 1 | Path B (forensic graph default) = 0 or unset
# IRONFRAME_INGEST_SOVEREIGN_BUS=1
# SHADOW_PLANE_ACTIVE=0
# NEXT_PUBLIC_SHADOW_PLANE_ACTIVE=0

# --- IronBoard Strategic Intel (Infasys KB → ironboard_crm_interactions) ---
# Organizational tenant UUID for Board-level Strategic Intel Update rows (defaults to Medshield seed tenant).
# IRONBOARD_BOARD_ORG_TENANT_UUID=5c420f5a-8f1f-4bbf-b42d-7f8dd4bb6a01

# Canonical YouTube URL for "Cybersecurity Reality: A Day in the Life of a GRC Analyst" board briefings.
# IRONBOARD_GRC_ANALYST_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID

# --- Identity & gateway (Supabase project kcuciqpxxrqjmqcpulmq) ---
# NEXT_PUBLIC_SUPABASE_URL=https://kcuciqpxxrqjmqcpulmq.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # anon JWT; iss ref must match project ref above
# SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-only — required for inviteUserByEmail
# DATABASE_URL=postgresql://postgres.kcuciqpxxrqjmqcpulmq:...@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.kcuciqpxxrqjmqcpulmq:...@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# --- Sales-assisted onboarding (invite-only; see config/registration.ts) ---
# Bearer token for POST /api/register/sales-intake (sales engineers / internal tooling only).
# INTERNAL_SALES_PROVISION_KEY=your-long-random-secret
# Public self-serve registration is hardcoded OFF in config/registration.ts — not env-driven.
# Path A staging tenant (BWC) stays hidden from Command Center until clean onboarding test:
# IRONFRAME_ENABLE_BWC_STAGING=1

# --- Get Started orientation audio (static files under public/training-audio; not under /docs/*) ---
# NEXT_PUBLIC_GET_STARTED_WELCOME_AUDIO_URL=/training-audio/get-started-welcome.mp3
# NEXT_PUBLIC_GET_STARTED_VIDEO_URL=/training-audio/get-started-orientation.mp3

# --- Legacy public prospect registration (disabled) ---
# IRONFRAME_PUBLIC_REGISTRATION_ENABLED is defined in config/registration.ts (false).

# --- Production ingress quarantine (middleware) ---
# Default: all non-local hosts return 403 (Vercel preview, production apex, tenant subdomains on cloud).
# Local: localhost, 127.0.0.1, *.lvh.me, *.localhost. Dev servers bind 127.0.0.1 only.
# To open public ingress for a deployed preview (not recommended during closed dev):
# IRONFRAME_ALLOW_PUBLIC_INGRESS=1

# --- Platform security administrator (GLOBAL_ADMIN) ---
# Hardcoded default in config/platformSecurity.ts: dwoods360@gmail.com
# Optional override for staging drills only:
# IRONFRAME_PLATFORM_GLOBAL_ADMIN_EMAIL=security-admin@your-domain.com
# Comma-separated extra emails for remote-access toggle (threat intervention panel):
# IRONFRAME_REMOTE_ACCESS_ADMIN_EMAILS=security-admin@your-domain.com

# --- Stripe instant checkout (async self-serve provisioning tunnel) ---
# Hosted Payment Link / Checkout URL — static outbound link on /pricing (no backend form).
# NEXT_PUBLIC_STRIPE_COMMAND_TIER_CHECKOUT_URL=https://buy.stripe.com/your_payment_link
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Checkout session metadata (required): slug, companyName — plus customer email from Stripe.
# Local webhook forward: stripe listen --forward-to http://127.0.0.1:3000/api/webhooks/stripe

# --- The Governance Frame (multi-zone local proxy) ---
# Next.js :3000 rewrites /governance-frame → IronBoard :8082
# GOVERNANCE_FRAME_UPSTREAM=http://127.0.0.1:8082
# IronBoard (:8082) → Ironframe core telemetry bridge (GET /api/board/shared-context)
# IRONFRAME_CORE_ORIGIN=http://127.0.0.1:3000

# --- External metrics gateways (placeholders only) ---
# OPEN_ENERGY_API_KEY=PLACEHOLDER_TOKEN_FOR_AUDIT_REVIEW
# NREL_DATA_INGRESS_SECRET=PLACEHOLDER_TOKEN_FOR_AUDIT_REVIEW

# ==============================================================================
# Extended reference (optional integrations)
# ==============================================================================

# Ironframe Runtime & Integration Environment Template
# Copy to .env.local and set real values per environment.

# --- Local environment summary ---
# • Never commit `.env.local` or real secrets; use this file as the shape-only template.
# • Prisma CLI (`migrate`, `generate`, `db seed`) loads root `.env`, then `.env.local`
#   (later file wins) via `prisma.config.ts` before resolving `DATABASE_URL` / `DIRECT_URL`.
# • Next.js reads `.env*` per framework rules; keep DB URLs consistent with Prisma for local dev.
# • Epic 7 Ironcast keys live in the section marked below; autonomous alerts need
#   `RESEND_API_KEY` + `THREAT_CONFIRMATION_RECIPIENTS` (or `SystemConfig.admin_alert_email`).

# Optional: absolute repo root (use forward slashes). On localhost, “View in TAS.md” constitutional links use vscode://file/…/docs/TAS.md:line in Cursor/VS Code.
# NEXT_PUBLIC_PROJECT_ROOT=C:/Users/you/ironframe-live

# --- Constitutional Human Root of Trust (Ironlock / Irontech emergency) ---
# Supabase user UUID or email permitted to submit the 64-char override key (not User_00 workforce).
# SYSTEM_OWNER_ID=SYSTEM_OWNER
# 64-character lowercase hex key — must match value entered in Constitutional Void overlay.
# CONSTITUTION_OVERRIDE_SECRET=

# --- Triple-Executive gate (TRIPARTITE → DUAL posture downgrade) ---
# 32-character lowercase hex administrative keys (distinct per role).
# CEO_KEY_AUTH=
# CFO_KEY_AUTH=
# CIO_KEY_AUTH=
# Optional: cool-down hours before posture applies (default 24).
# POSTURE_DEGRADATION_COOLDOWN_HOURS=24

# --- Dead Man's Switch (constitutional void 24h TTL) ---
# DEAD_MAN_SWITCH_TTL_HOURS=24

# --- Witness log collusion gate (tripartite CISO + Staff same fingerprint) ---
# SECONDARY_BIOMETRIC_MFA_TOKEN=

# --- Last Will and Testament (pre-DMS off-site forensic archive) ---
# LWT_ENCRYPTION_KEY=  # min 16 chars; AES-256-GCM (falls back to NOTIFICATION_ENDPOINT_SECRET)
# LWT_FORENSIC_ENDPOINT_URL=https://forensic-logger.example.com/api/lwt
# LWT_FORENSIC_FETCH_URL=https://forensic-logger.example.com/api/lwt
# LWT_FORENSIC_BEARER_TOKEN=
# LWT_PRE_DMS_SECONDS=30

# --- Local simulation lab (middleware): localhost + this secret bypasses x-tenant / x-target isolation 403 for bot harnesses
# SIMULATION_SECRET=
# Shadow plane kill-switch for API routes (ingest / simulation-audit metadata) — pair with ironframe-simulation-mode=1 cookie
# SHADOW_PLANE_ACTIVE=true
# Browser mirror for UI (handshake / pipeline “live range”) — optional; same semantics as SHADOW_PLANE_ACTIVE
# NEXT_PUBLIC_SHADOW_PLANE_ACTIVE=true

# --- Database (Prisma; see prisma/schema.prisma) ---
# DATABASE_URL=
# DIRECT_URL=
# Epic 15: LangGraph PostgresSaver checkpoint pool — CI must use 127.0.0.1 ephemeral Postgres (not remote Supabase).

# Epic 14 / Ironethic: HMAC pepper for inbound PII hashing (email, fullName, phoneNumber, operatorInitials, nationalId).
# Production requirement: high-entropy secret (recommended 32+ random bytes, base64/hex) and never blank.
# INGEST_SALT_PEPPER=
# Agent 17 / pg_cron companion: Bearer or x-cron-secret for POST /api/internal/cron/agent17-sentinel
# IRONFRAME_CRON_SECRET=
# Briefing queue: escalate drafts when tenant active exposure (whole cents) meets or exceeds threshold ($50k default)
# INTERNAL_ALERT_EXPOSURE_THRESHOLD_CENTS=5000000
# Slack/Discord webhook for urgent HITL promotion when exposure threshold is exceeded (nightly narrate)
# INTERNAL_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# Epic 10.5: set to 1 to skip orchestration on POST /api/threats/ingest (or pass skipOrchestrationBus in body)
# IRONFRAME_INGEST_BUS_DISABLED=
# Ingest orchestration lane: forensic graph is default; set to 1 to force sovereign document bus
# IRONFRAME_INGEST_SOVEREIGN_BUS=
# Set to 0 to opt out of forensic graph (same as IRONFRAME_INGEST_SOVEREIGN_BUS=1)
# IRONFRAME_INGEST_FORENSIC_GRAPH=
# Alias accepted by gridcore-rate-poll and other internal cron routes:
# CRON_SECRET=
# Optional: dedicated secret for middleware → GET /api/internal/stale-lockdown-status (falls back to IRONFRAME_CRON_SECRET)
# IRONFRAME_INTERNAL_GATES_SECRET=
# Also used by POST /api/internal/cron/sustainability-achievement-report (daily; 30-day self-healing milestones → Ironscribe PDF).
# Cross-host workspace session bootstrap — opaque single-use tickets (≤30s TTL; server memory store)
# For horizontally scaled deployments, back this store with a shared cache or durable table.
# IRONFRAME_WORKSPACE_BOOTSTRAP_SECRET=
# Investor report time-bound links: HMAC signing key (72h tokens for /api/grc/investor-reports/download)
# INVESTOR_REPORT_SHARE_SECRET=
# Public transparency page — sanitized JSON + PDF link to CMS (Framer / Webflow / custom). Outbound POST HMAC: X-Ironframe-Transparency-Signature: sha256=<hex>
# TRANSPARENCY_PAGE_WEBHOOK_URL=
# TRANSPARENCY_PAGE_WEBHOOK_SECRET=
# Optional: Bearer for POST /api/webhooks/transparency-page (peek or replay push)
# TRANSPARENCY_WEBHOOK_INGRESS_SECRET=
# Optional: long-lived PDF download token for badge / CMS (default 90d)
# TRANSPARENCY_PDF_LINK_TTL_MS=
# When "1", VMAT Carbon ROI disclosure marks evidenceBindingOk false unless Ironlock throttle SHA-256 exists in Carbon Pulse.
# VMAT_REQUIRE_THROTTLE_EVIDENCE=
# Canonical public origin for absolute pdfLink / truthBadgeUrl in outbound payloads
# Production: https://ironframegrc.com — also used for Supabase Auth redirects and multi-tenant subdomain routing.
# NEXT_PUBLIC_APP_URL=https://ironframegrc.com

# --- Multi-tenant subdomain routing (middleware) ---
# Enabled by default. Set IRONFRAME_SUBDOMAIN_TENANCY=0 to disable host → tenant binding.
# IRONFRAME_SUBDOMAIN_TENANCY=1
# Production apex for *.ironframegrc.com tenant hosts (defaults from NEXT_PUBLIC_APP_URL hostname).
# IRONFRAME_TENANT_APEX_DOMAIN=ironframegrc.com
# Local dev: self-onboarding at http://localhost:3000/register/setup; workspace at http://{slug}.lvh.me:3000
# (wildcard *.lvh.me → 127.0.0.1 — no OS hosts file). Legacy: IRONFRAME_LOCAL_TENANT_HOST=localhost
# NEXT_PUBLIC_DEVELOPMENT_DOMAIN=lvh.me:3000
# for `{slug}.localhost:3000`. New clients: provision tenant in DB first (`provisionCorporateTenantAction`),
# then invite via `inviteCorporateTenantUserAction`.
# Requires IRONFRAME_CRON_SECRET (or IRONFRAME_INTERNAL_GATES_SECRET) for middleware slug→UUID resolution.
# Supabase Auth → URL Configuration: add redirect URLs per tenant workspace, e.g.
#   http://vaultbank.lvh.me:3000/**
#   http://acmecorp.lvh.me:3000/**
#   https://acmecorp.ironframegrc.com/**

# --- Playwright E2E (production smoke against live Vercel) ---
# Requires DATABASE_URL, SUPABASE_SERVICE_ROLE_KEY, NEXT_PUBLIC_SUPABASE_* in .env.local
# E2E_PRODUCTION=1 — target https://{slug}.ironframegrc.com (no local webServer)
# E2E_TENANT_APEX_DOMAIN=ironframegrc.com
# E2E_TENANT_ORIGIN=https://bwc.ironframegrc.com — optional single-tenant override
# E2E_BWC_OPERATOR_EMAIL=wil@blackwoodscoffee.com
# Run: npm run test:e2e:production:bwc
#
# Scheduled CI (GitHub Actions): .github/workflows/production-bwc-smoke.yml
#   - cron 06:00 America/Chicago (11:00 UTC) when PRODUCTION_BWC_SMOKE_ENABLED=true
#   - optional PRODUCTION_SMOKE_ALERT_WEBHOOK for Slack/Discord on failure

# --- Epic 11 Bank Vault: supervisor PKI (Gate A RSA-SHA256) ---
# Production (Vercel): primary vault attestation PEM — checked before PUBLIC_KEY_VAULT_RELEASE.
# PUBLIC_KEY_VAULT_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# CISO dual-gate handshake (production alias: PUBLIC_KEY_CISO_PEM).
# PUBLIC_KEY_CISO_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Key id must match the dynamic env suffix (normalized to UPPER_SNAKE).
# PUBLIC_KEY_ID=vault-key-2026
# PUBLIC_KEY_VAULT_RELEASE=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# PUBLIC_KEY_CISO_HANDSHAKE=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# PUBLIC_KEY_VAULT_KEY_2026=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Optional fallbacks (dev only — replace in staging/production):
# PUBLIC_KEY=
# VAULT_SUPERVISOR_PUBLIC_KEY=

# --- Epic 10 / 16: LangGraph + Ironquery RAG (sovereign bus, forensic graph) ---
# GOOGLE_API_KEY=

# --- Ironbloom Gridcore (Agent 18): utility rate polling ---
# OpenEI URDB + NLR utility_rates/v3 (US zip lookups); key from https://developer.nlr.gov
# GlobalPetrolPrices (international industrial rates): GLOBAL_PETROL_API_KEY
# OPEN_ENERGY_API_KEY=
# GLOBAL_PETROL_API_KEY=
# Cron: POST /api/internal/cron/gridcore-rate-poll (utility 30-day cadence ?force=1; carbon sync every run; ?utility=0 / ?carbon=0)
# Monthly Budget Reallocation: POST /api/internal/cron/carbon-budget-reallocation (UTC day 1; schedule 0 9 1 * *)
# IRONBLOOM_MONTHLY_CARBON_BUDGET_THRESHOLD_CENTS=5000000

# --- Ironbloom Sustainability ALE (Agent 18): carbon intensity + offset price ---
# Epic 9/5 — live carbon ingress (Production + Preview). Obtain from https://electricitymaps.com
# ELECTRICITY_MAPS_API_KEY=
# Alternate / reserve aliases (multi-tenant ingress normalizer also checks these):
# ELECTRICITY_MAPS_RESERVE_KEY=
# _API_KEY=
# When unset or upstream 429/5xx/timeout: forensic US-MN anchor (380 gCO₂/kWh ±2.5%) — see [ironbloom-carbon-ingress] logs
# Do NOT use mock_staging_key in production (triggers tenant baseline fallback, not live grid data)
# Optional probe zone for Ironwatch heartbeat (default US-CA; roster tenants use tenantCarbonZones.ts)
# IRONWATCH_ELECTRICITY_MAPS_ZONE=US-MIDW-MISO
# Dirty-grid Ironlock throttle threshold (gCO₂eq/kWh; default 400)
# TENANT_CARBON_THRESHOLD=400
# Voluntary / EU ETS offset price per metric ton (default $100 → 10000 cents/ton)
# CARBON_OFFSET_PRICE_USD_PER_TON=100

# --- Ironframe nightly pipeline (staggered — doc engine then GRC narrate) ---
# 03:00 local — Documentation Engine: scripts/cron_narrate_scheduled.ps1 → scripts/cron_narrate.ps1
# 03:30 local — GRC Narrative Hydration: scripts/cron_narrate_api_scheduled.ps1 → bin/cron_narrate.ps1
# Vercel (UTC): ironwatch-api-heartbeat 03:00, /api/cron/narrate 03:30 (vercel.json)
# Register both Windows tasks: powershell -File scripts/register-nightly-cron-tasks.ps1
# Headless Cursor CLI Writer run — requires agent CLI + CURSOR_API_KEY (User env or .env.local).
# CURSOR_API_KEY=your-cursor-api-key

# --- Supabase (required by role dashboards and shared client) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-only — corporate B2B invite provisioning (app/actions/admin/inviteCorporateTenantUser.ts)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Canonical origin for Supabase Auth redirect URLs (password reset + corporate invite callbacks)
# Production: https://ironframegrc.com
# NEXT_PUBLIC_APP_URL=https://ironframegrc.com


# --- Email: Zoho SMTP (all notifications — threat confirm, GRC routing, vendor alerts) ---
# From address will match ZOHO_EMAIL_USER; use the exact Zoho account email.
ZOHO_EMAIL_USER=your-zoho-account@yourdomain.com
ZOHO_EMAIL_PASS=your-zoho-app-password

# THREAT_CONFIRMATION_RECIPIENTS — set under "Epic 7: Ironcast Escalation" below (autonomous + threat alerts).

# Enterprise GRC distribution (routeRiskNotification): set for your org or leave defaults.
# GRC_EMAIL_EXECUTIVE=ciso@yourcompany.com
# GRC_EMAIL_OPERATIONAL=soc-leads@yourcompany.com
# GRC_EMAIL_COMPLIANCE=grc-team@yourcompany.com

# --- Legacy Zoho (vendor-only; prefer ZOHO_EMAIL_* above for consistency) ---
# ZOHO_USER=your-zoho-sender@example.com
# ZOHO_PASS=your-zoho-app-password

# --- Financial Impact Engine (Phase 20 forward-looking knobs) ---
# Optional overrides for future externalization from scoring defaults.
FINANCIAL_IMPACT_BASELINE_MEDSHIELD=11100000
FINANCIAL_IMPACT_BASELINE_VAULTBANK=5900000
FINANCIAL_IMPACT_BASELINE_GRIDCORE=4700000
FINANCIAL_IMPACT_CRITICAL_EVENT_MEDSHIELD=1500000
FINANCIAL_IMPACT_CRITICAL_EVENT_VAULTBANK=850000
FINANCIAL_IMPACT_CRITICAL_EVENT_GRIDCORE=600000

# --- Epic 12: WORM evidence storage ---
# EVIDENCE_STORAGE_BUCKET=evidence-locker
# EVIDENCE_WORM_BUCKET=evidence-locker-worm
# INCIDENT_REPORTS_BUCKET=evidence-locker
# EVIDENCE_WORM_OBJECT_LOCK=true
# EVIDENCE_WORM_STRICT=1

# --- AWS Hook (upcoming ingestion + evidence sync) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=
AWS_CLOUDTRAIL_BUCKET=your-cloudtrail-bucket
AWS_EVIDENCE_PREFIX=ironframe/evidence
AWS_HOOK_ENABLED=false

# Epic 7b: Ironcast State Freeze — PagerDuty (Constitutional Authority Events API v2) + optional Twilio CISO voice (T+5m ladder; see src/services/ironcast/stateFreezeCisoEscalation.ts).
# Optional: POST JSON diagnostic when Ironlock `state_freeze_active` engages (Ironwatch Ironguard circuit breaker); see `src/services/ironlock/freezeEngine.ts`.
# IRONFRAME_DEV_DIAGNOSTIC_WEBHOOK_URL=
# IRONFRAME_DEV_DIAGNOSTIC_WEBHOOK_SECRET=

# Local constitutional authority (development only — never enable in production).
# Elevates Meta-Audit Console, HITL Review Queue, and CISO handshake for your Supabase session.
# Set IRONFRAME_DEV_SUPABASE_EMAIL (or USER_ID), or IRONFRAME_DEV_CONSTITUTIONAL_ELEVATION=1 for your dev account only.
# Other authenticated users keep normal RBAC tenant isolation.
# IRONFRAME_DEV_CONSTITUTIONAL_ELEVATION=1
# IRONFRAME_DEV_SUPABASE_USER_ID=your-supabase-auth-users-uuid
# IRONFRAME_DEV_SUPABASE_EMAIL=you@example.com
# Routing key from the PagerDuty "Constitutional Authority" Events API integration (not the generic REST API key).
# PAGERDUTY_CONSTITUTIONAL_AUTHORITY_ROUTING_KEY=
# E.164 emergency line for outbound voice after statutory delay when Irontech State Freeze persists.
# IRONCAST_CISO_EMERGENCY_PHONE=+15551234567
# Twilio Programmable Voice (Account SID + Auth Token + caller ID)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VOICE_FROM_NUMBER=

# Epic 7: Ironcast Escalation - Required for autonomous security notifications
# Mirror secrets in your secret store for staging/production. Local: copy to .env.local.
RESEND_API_KEY=
IRONCAST_FROM_NAME=Ironframe Security Agents
IRONCAST_REPLY_TO=alerts@your-domain.com
THREAT_CONFIRMATION_RECIPIENTS=
# Optional: verified Resend From domain (see Resend dashboard)
# IRONCAST_FROM_EMAIL=notifications@your-verified-domain.com
# Optional: live Vitest smoke (`__tests__/integration/ironcast-escalation.test.ts`); omit to skip
# IRONCAST_SMOKE_RECIPIENT=
# IRONCAST_SMOKE_TEST_EMAIL=

# --- Governance Frame briefing promotion (human gate) ---
# Whole cents; narrate cron sets requiresImmediatePromotion when exposure meets/exceeds threshold.
# INTERNAL_ALERT_EXPOSURE_THRESHOLD_CENTS=5000000
# Explicit operator ack before promote-briefing-draft.ts writes to Postgres (data tests).
# IRONFRAME_BRIEFING_DATA_TEST_ACK=1
# Required with --deploy when syncing brief.ironframegrc.com via sync:brief:gcs.
# IRONFRAME_BRIEFING_DEPLOY_ACK=1

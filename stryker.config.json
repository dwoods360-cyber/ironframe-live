{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "mutate": [
    "core/irontrust/**/*.ts",
    "Ironboard/src/services/marketIntelligence.ts",
    "Ironboard/src/components/flywheelScore.ts",
    "app/(dashboard)/boardroom/**/*.ts",
    "!**/*.test.ts"
  ],
  "thresholds": { "high": 85, "low": 80, "break": 75 }
}
